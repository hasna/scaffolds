{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@api/*": ["./api/*"],
      "@web/*": ["./web/src/*"]
    },
    "types": ["bun-types"],
    "jsx": "react-jsx"
  },
  "include": [
    "api/**/*.ts",
    "cli/**/*.ts",
    "shared/**/*.ts",
    "blog.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
