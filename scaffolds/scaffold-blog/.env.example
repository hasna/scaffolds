# Database
DATABASE_URL=postgresql://user:pass@host:5432/db
SQLITE_PATH=./data/blog.db

# Server
PORT=3000
# {{baseUrl}} — public-facing base URL of this API (no trailing slash)
# e.g. http://localhost:3000 in development, https://api.yourdomain.com in production
API_URL=http://localhost:3000

# Auth
JWT_SECRET=change-this-to-a-secure-secret

# OAuth — Google
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OAuth — GitHub
# Create an OAuth App at https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# OAuth callback base URL (must match the Authorized Redirect URI in each provider's console)
# Pattern: {{baseUrl}}/api/auth/oauth  (the provider name + /callback is appended automatically)
# e.g. http://localhost:3000/api/auth/oauth  →  registered as:
#   Google: http://localhost:3000/api/auth/oauth/google/callback
#   GitHub: http://localhost:3000/api/auth/oauth/github/callback
AUTH_CALLBACK_URL=http://localhost:3000/api/auth/oauth

# Magic link email (via Resend — https://resend.com)
RESEND_API_KEY=
AUTH_EMAIL_FROM=noreply@example.com

# AI - OpenAI
OPENAI_API_KEY=

# AI - Anthropic (Claude Agent SDK)
ANTHROPIC_API_KEY=

# AI - Google (Gemini)
GOOGLE_API_KEY=

# Storage (S3 - optional)
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
