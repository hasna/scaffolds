    "dev:web": "vite --config web/vite.config.ts",
    "build": "vite build --config web/vite.config.ts",
    "start": "bun api/index.ts",
    "cli": "bun cli/index.ts",
    "test": "bun test",
    "db:seed": "bun api/db/seed.ts",
    "images:warm-cache": "bun scripts/warm-image-cache.ts"
  },
  "dependencies": {
