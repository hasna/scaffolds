    "@hono/zod-validator": "^0.7.5",
    "bcrypt": "^5.1.0",
    "date-fns": "^4.1.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "nanoid": "^5.0.0",
    "node-cron": "^3.0.0",
    "openai": "^4.70.0",
    "pg": "^8.16.3",
    "sharp": "^0.34.5",
    "slugify": "^1.6.0",
    "zod": "^3.23.0"
