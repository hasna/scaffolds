# Provider selection
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-sonnet-4-6
AGENT_SYSTEM_PROMPT=You are a helpful AI agent.
AGENT_TASK=Report the current status.
AGENT_LOOP_INTERVAL_MS=5000

# Anthropic API
ANTHROPIC_API_KEY=your_key_here

# OpenAI API
OPENAI_API_KEY=your_key_here

# Model configuration (Claude-specific)
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TURNS=50
MAX_BUDGET_USD=10.0

# Database (for custom tools)
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# Telemetry
TELEMETRY_ENDPOINT=https://telemetry.example.com
TELEMETRY_API_KEY=

# WebSocket (for progress listener)
WS_PORT=3001

# Security
ALLOWED_PATHS=/workspace,/tmp
BLOCKED_COMMANDS=rm -rf,sudo,chmod 777

# Logging
LOG_LEVEL=info
