# App
PORT=5900
NEXT_PUBLIC_APP_URL=http://localhost:5900
NEXT_PUBLIC_APP_NAME="Competition Platform"
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scaffold_competition
DB_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=your-secret-key-min-32-chars-long-here
AUTH_URL=http://localhost:5900
ADMIN_EMAILS=admin@example.com

# Google OAuth
AUTH_GOOGLE_ID=xxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxx

# GitHub OAuth
AUTH_GITHUB_ID=xxx
AUTH_GITHUB_SECRET=xxx

# Email (Resend) — used for magic link auth and transactional emails
AUTH_EMAIL_FROM=noreply@example.com
AUTH_EMAIL_SERVER=smtp://username:password@smtp.example.com:587
RESEND_API_KEY=re_xxx

# Storage (S3)
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=my-bucket

# AI Providers
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
AI_DEFAULT_MODEL=gpt-4o

# Webhooks
WEBHOOK_SIGNING_SECRET=whsec_xxx
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=60000

# Monitoring (Sentry)
SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=scaffold-competition
SENTRY_AUTH_TOKEN=xxx
