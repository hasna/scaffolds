# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:5900
NEXT_PUBLIC_APP_NAME=ReviewHub

# Database
DATABASE_URL=postgresql://scaffold:scaffold_dev@localhost:5432/scaffold_review

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=your-secret-key-here-at-least-32-chars
AUTH_URL=http://localhost:5900

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email (Resend) — used for magic link auth and transactional emails
RESEND_API_KEY=re_
AUTH_EMAIL_FROM=noreply@example.com
AUTH_EMAIL_SERVER=smtp://username:password@smtp.example.com:587

# OpenAI (for AI Assistant)
OPENAI_API_KEY=sk-
