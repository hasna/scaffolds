{
  "name": "@hasna/scaffolds",
  "version": "0.0.1",
  "description": "App scaffolds for AI agents — saas, agent, blog, news, social, competition, review, landing pages",
  "type": "module",
  "bin": {
    "scaffolds": "./bin/index.js",
    "scaffolds-mcp": "./bin/mcp.js"
  },
  "files": [
    "bin/",
    "dist/",
    "scaffolds/",
    "!scaffolds/**/node_modules",
    "!scaffolds/**/bun.lock",
    "!scaffolds/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun build ./src/cli/index.tsx --outdir ./bin --target bun --external ink --external react --external chalk --external conf && bun build ./src/mcp/index.ts --outfile ./bin/mcp.js --target bun && bun build ./src/index.ts --outdir ./dist --target bun",
    "dev": "bun run ./src/cli/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test --path-ignore-patterns 'scaffolds/**' src/lib/",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "scaffolds",
    "ai",
    "agent",
    "saas",
    "blog",
    "social",
    "starter",
    "template",
    "cli",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Hasna",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.2.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasna/open-scaffolds.git"
  }
}
